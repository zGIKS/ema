# Facial recognition runtime defaults (optional)
# Copy to .env and export it, or load it from your shell.
#
# Example:
#   set -a; source .env; set +a
#   uv run python -m src.main

# Model / InsightFace
FR_MODEL_NAME=buffalo_l
FR_MODEL_ROOT=.
FR_DET_W=640
FR_DET_H=640

# Decision defaults
FR_METRIC=cosine
FR_THRESHOLD=0.60
FR_MIN_MARGIN=0.03
FR_MIN_DET_SCORE=0.50
FR_TOPK=1

# Paths
FR_DATA_ROOT=data
FR_OUTPUT_DIR=output
FR_Q_POLICY_PATH=data/q_policy.json

